{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "lib": ["es2020"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": true,
    "types": ["node", "jest"]
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}
