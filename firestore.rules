rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Custom Claims helper functions (ZERO READ COST)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.superAdmin == true;
    }
    
    function isAdmin() {
      return (isSuperAdmin() || (request.auth != null && request.auth.token.admin == true)) && !isBanned();
    }

    function isModerator() {
      return request.auth != null && (request.auth.token.moderator == true || isAdmin()) && !isBanned();
    }

    function isBanned() {
      return request.auth != null && request.auth.token.banned == true;
    }
    
    match /user/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Writing allowed only if not banned. isAdmin/superAdmin can write to any user doc.
      allow write: if request.auth != null && request.auth.uid == userId && !isBanned();
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && !isBanned();
    }

    match /rivers/{riverId} {
      allow read: if true; 
      allow create, update, delete: if isAdmin() && !isBanned();
    }

    match /reviewQueue/{queueId} {
      allow read: if isModerator(); 
      allow create: if !isBanned(); // Anonymous allowed unless banned (if we implemented anon banning)
      allow update, delete: if isModerator() && !isBanned();
    }

    match /community_lists/{listId} {
      allow read: if true;
      allow create: if request.auth != null && !isBanned();
      allow update, delete: if request.auth != null && !isBanned() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && !isBanned(); // Frontend writes directly
      allow update, delete: if false; // Append-only audit log
    }
    
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
