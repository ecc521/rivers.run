rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Server-Side Verification Native Logic: 
    // Checks if logged in, AND the user document has isAdmin == true
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/user/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/user/$(request.auth.uid)).data.isAdmin == true;
    }
    
    match /user/{userId} {
      // Users can read/write their own user profile, but ONLY admins can write 'isAdmin' flags
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && !request.resource.data.keys().hasAny(['isAdmin']);
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      // Legacy support block (no admin access required for old data)
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && !request.resource.data.keys().hasAny(['isAdmin']);
    }

    match /rivers/{riverId} {
      allow read: if true; // Public access for the frontend catalog
      // Only strictly-verified admins can write to the live production database
      allow create, update, delete: if isAdmin();
    }

    match /reviewQueue/{queueId} {
      allow read: if isAdmin(); // Queue is invisible to the public
      allow create: if request.auth != null; // Any user can submit a river
      allow update, delete: if isAdmin(); // Only admins can delete/edit from the queue
    }

    match /community_lists/{listId} {
      allow read: if true; // Public access for viewing the lists feature
      allow create, update, delete: if isAdmin();
    }
    
    // Fallback for any other existing collections
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
