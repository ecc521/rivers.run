{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023"],
    "alwaysStrict": true,
    "strict": true,
    "preserveConstEnums": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "src/__tests__/**/*.ts"],
  "exclude": ["node_modules"]
}
