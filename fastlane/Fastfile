# Rivers.run — Fastlane Configuration
# Metadata-only setup. No binary builds or screenshot uploads (yet).
#
# Usage:
#   fastlane ios metadata      — Upload iOS metadata to App Store Connect
#   fastlane ios fetch          — Download current live metadata from App Store Connect
#   fastlane android metadata  — Upload Android metadata to Google Play
#
# Setup (one-time):
#   1. Install fastlane: brew install fastlane
#   2. iOS: Generate an App Store Connect API key
#      - App Store Connect → Users & Access → Integrations → App Store Connect API
#      - Click "+" to generate a key with "App Manager" role
#      - Download the .p8 file → save to fastlane/AuthKey.p8
#      - Note the Key ID and Issuer ID → fill in below
#   3. Android: Create a Google Play service account
#      - Google Cloud Console → IAM → Service Accounts → Create
#      - Grant "Service Account User" role
#      - Google Play Console → Setup → API Access → link the service account
#      - Grant "Release manager" or "Admin" permission to the service account
#      - Download JSON key → save to fastlane/play-store-key.json

default_platform(:ios)

# ── iOS ──────────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Upload metadata (descriptions, keywords, release notes) to App Store Connect"
  lane :metadata do
    deliver(
      api_key: {
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"]),
        in_house: false,
      },

      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      metadata_path: "./metadata/ios/en-US",
      force: true,  # Skip the HTML preview confirmation
      precheck_include_in_app_purchases: false
    )
  end

  desc "Download current live metadata from App Store Connect to metadata/ios/en-US/"
  lane :fetch do
    deliver(
      api_key: {
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"]),
        in_house: false,
      },
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      metadata_path: "./metadata/ios/en-US"
    )
  end

end

# ── Android ──────────────────────────────────────────────────────────────────────

platform :android do

  desc "Upload metadata (descriptions, release notes) to Google Play"
  lane :metadata do
    supply(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      metadata_path: "./metadata/android"
    )
  end

end
