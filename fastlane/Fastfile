# Rivers.run — Fastlane Configuration
#
# fastlane uploads the binaries (you export the IPA / build the AAB) and all
# store metadata. It does not build/sign the binaries — archive in Xcode and
# Generate Signed Bundle in Android Studio, then point these lanes at the output.
#
# Lanes:
#   fastlane ios metadata          — Push iOS listing + release notes (creates the version if needed)
#   fastlane ios release ipa:<path>
#                                  — Upload an exported IPA + listing/notes to App Store Connect
#   fastlane ios fetch             — Pull current live iOS metadata back into metadata/ios
#   fastlane android metadata      — Push the Play Store listing (descriptions only)
#   fastlane android release aab:<path>
#                                  — Upload a signed AAB + release notes to Production
#                                    as a DRAFT for you to review & publish in the Console
#
# Required environment variables:
#   iOS      ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_FILEPATH (.p8), FASTLANE_APPLE_ID
#   Android  PLAY_JSON_KEY_FILE  (e.g. ~/Documents/Keys/play-store-rivers-run.json)
#
# Play service account needs: "Manage store presence" (metadata) and
# "Release to production, exclude devices, and use Play App Signing" (release lane).

default_platform(:ios)

# App Store Connect API key, built from env vars (shared by all iOS lanes).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"]),
    in_house: false
  )
end

# The iOS marketing version, read from the native project (source of truth).
# deliver uses this to create the App Store version if it doesn't exist, else edit it.
def ios_app_version
  pbxproj = File.expand_path("../ios/App/App.xcodeproj/project.pbxproj", __dir__)
  File.read(pbxproj)[/MARKETING_VERSION = ([0-9.]+);/, 1]
end

# ── iOS ──────────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Push iOS listing + release notes to App Store Connect (creates the version if needed)"
  lane :metadata do
    deliver(
      api_key: asc_api_key,
      app_version: ios_app_version,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: false,  # create the version if missing, otherwise edit it
      metadata_path: "./metadata/ios",
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload an exported IPA + listing/release notes to App Store Connect (creates the version if needed)"
  lane :release do |options|
    ipa = options[:ipa] || ENV["IOS_IPA_PATH"]
    UI.user_error!(
      "Provide the exported IPA path, e.g.\n" \
      "  fastlane ios release ipa:build/RiversRun.ipa"
    ) unless ipa

    deliver(
      api_key: asc_api_key,
      ipa: File.expand_path(ipa),
      app_version: ios_app_version,
      skip_binary_upload: false,
      skip_screenshots: true,
      skip_app_version_update: false,
      metadata_path: "./metadata/ios",
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Download current live metadata from App Store Connect to metadata/ios/en-US/"
  lane :fetch do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      metadata_path: "./metadata/ios"
    )
  end

end

# ── Android ──────────────────────────────────────────────────────────────────────

platform :android do

  desc "Update the Play Store listing only (descriptions etc. — no release notes, no binary)"
  lane :metadata do
    supply(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,   # release notes ride with the AAB in `release`
      skip_upload_images: true,
      skip_upload_screenshots: true,
      metadata_path: "./metadata/android"
    )
  end

  desc "Upload a signed AAB + release notes to Production as a DRAFT (review & publish in the Console)"
  lane :release do |options|
    aab = options[:aab] || ENV["ANDROID_AAB_PATH"]
    UI.user_error!(
      "Provide the signed AAB path, e.g.\n" \
      "  fastlane android release aab:android/app/release/app-release.aab"
    ) unless aab

    supply(
      aab: File.expand_path(aab),
      skip_upload_apk: true,
      skip_upload_metadata: true,     # store listing is handled by the `metadata` lane
      skip_upload_changelogs: false,  # attach the version's release notes
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft",        # uploads only — you publish manually from the Console
      metadata_path: "./metadata/android"
    )
  end

end
